@attribute [Route(PageRoutes.AccessDenied)]
@attribute [Route(PageRoutes.AccessDenied_FR)]

@layout HeaderPublicLayout

@inject Microsoft.FeatureManagement.IFeatureManagerSnapshot _featureManager
@inject IUserInformationService _userInformationService
@inject ILogger<AccessDeniedPage> _logger;

<PageTitle>@Localizer["Access Denied - Federal Science DataHub"]</PageTitle>


<MudStack AlignItems="AlignItems.Center" Class="mt-4" Style="width: 100%">
    <DHIcon Icon="@Icons.Material.Filled.Error" />
    <MudText Typo="Typo.h4" Class="text-center">
        <strong>
            @Localizer["Access Denied"]
        </strong>
    </MudText>
	@if (_traceClaims && _externalUserId is not null)
	{
		<MudText Typo="Typo.h6" Class="text-center">
			@Localizer["Your external user ID is: {0}", _externalUserId]
		</MudText>
	}
	<MudText Typo="Typo.h6" Class="text-center">
        @Localizer["This site is monitored. Further attempts to log in may be reported to the authorities."]
    </MudText>
</MudStack>


@code
{
	private bool _traceClaims = false;
	private string? _externalUserId = null;

	protected override async Task OnInitializedAsync()
	{
		_traceClaims = await _featureManager.IsEnabledAsync(Features.Trace_Claims);
		if (_traceClaims)
		{
			if ((await _userInformationService.IsExternalUser()))
			{
				_externalUserId = await _userInformationService.GetExternalUserNameIdentifier();
				_logger.LogInformation("Access Denied page accessed by external user with ID: {ExternalUserId}", _externalUserId);
			}
			else
			{				
				_logger.LogInformation("Access Denied page accessed by internal user.");
			}
		}
	}
}
