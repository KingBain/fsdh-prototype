@page "/metadata/{ObjectId}"
@using Datahub.Application.Services.Metadata
@using MudBlazor

<div style="margin: 2rem">
    <DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.DatahubSupport">
        <Authorized>
            <MudCard>
                <MudCardHeader>
                    <h2>Metadata</h2>
                </MudCardHeader>
                <MudCardContent>
                    <ObjectMetadataEditor @ref="_objectMetadataEditor"
                                          ObjectId=@ObjectId
                                          ProfileName="catalog"
                                          UpdateCatalog="false"
                                          Preview />
                </MudCardContent>
            </MudCard>
        </Authorized>
        <NotAuthorized>
            <MudText Typo="Typo.h3">You are not authorized to view this page.</MudText>
        </NotAuthorized>
    </DatahubAuthView>
</div>

@code {

    [Inject]
    public IMetadataBrokerService MetadataBrokerService { get; set; }

    private ObjectMetadataEditor _objectMetadataEditor;

    /// <summary>
    /// Object ID to edit or add metadata
    /// </summary>
    [Parameter]
    public string ObjectId { get; set; } = "6a1a65b9-6cc9-4d12-810c-038f8add752c";

