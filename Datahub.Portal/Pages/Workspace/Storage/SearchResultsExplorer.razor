@using Datahub.Core.Storage
@using Datahub.Core.Data
@inject ILogger<SearchResultsExplorer> Logger
@inject IJSRuntime JSRuntime

<MudStack>
    @if (IsLoading)
    {
        <div class="file-explorer-layout" style="width: 100%; border-collapse: collapse;">
            <div class="file-list-header" style="display: table-header-group; background-color: #f5f5f5; font-weight: bold;">
                <div class="file-list-cell" style="display: table-cell; padding: 8px 16px;">@Localizer["Name"]</div>
                <div class="file-list-cell" style="display: table-cell; padding: 8px 16px;">@Localizer["Path"]</div>
                <div class="file-list-cell" style="display: table-cell; padding: 8px 16px;">@Localizer["Size"]</div>
                <div class="file-list-cell" style="display: table-cell; padding: 8px 16px;">@Localizer["Last Modified"]</div>
            </div>
            @for (int i = 0; i < 2; i++)
            {
                <div class="file-list-row" style="display: table-row;">
                    <div class="file-list-cell" style="display: table-cell; padding: 8px 16px; border-bottom: 1px solid #ddd;">
                        <MudSkeleton Width="200px" Height="1.5rem" />
                    </div>
                    <div class="file-list-cell" style="display: table-cell; padding: 8px 16px; border-bottom: 1px solid #ddd;">
                        <MudSkeleton Width="300px" Height="1.5rem" />
                    </div>
                    <div class="file-list-cell" style="display: table-cell; padding: 8px 16px; border-bottom: 1px solid #ddd;">
                        <MudSkeleton Width="100px" Height="1.5rem" />
                    </div>
                    <div class="file-list-cell" style="display: table-cell; padding: 8px 16px; border-bottom: 1px solid #ddd;">
                        <MudSkeleton Width="150px" Height="1.5rem" />
                    </div>
                </div>
            }
        </div>
    }
    else if (SearchResults == null || !SearchResults.Any())
    {
        <MudText>@Localizer["No results found."]</MudText>
    }
    else
    {
        <CascadingValue Value="@StorageAccountMetadata" Name="StorageAccountMetadata">
            <div class="file-explorer-layout-wrapper">
                <div class="file-explorer-layout">
                    <div class="file-list">
                        <div class="file-list-header">
                            <MudText>&nbsp;</MudText>
                            <MudText>@Localizer["Name"]</MudText>
                            <MudText>@Localizer["Size"]</MudText>
                            <MudText>@Localizer["Last Modified"]</MudText>
                        </div>

                        @if (SearchResults != null && SearchResults.Any())
                        {
                            @foreach (var result in SearchResults.Where(r => r != null))
                            {
                                var file = _files.FirstOrDefault(f => f.name.Equals(result.Name, StringComparison.OrdinalIgnoreCase));
                                if (file != null)
                                {
                                    var fileSize = file.filesize ?? "0";

                                    <FileItem Name="@result.Name"
                                              Modified="@(file?.lastmodifiedts ?? DateTime.MinValue)"
                                              Size="@fileSize"
                                              @onclick="@(() => HandleFileSelectionClick(result))"
                                              OnSelectionClick="() => HandleFileSelectionClick(result)"
                                              Highlighted="SelectedFile != null && SelectedFile.Name == result.Name && SelectedFile.Path == result.Path">
                                        <Icon>
                                            <i class="@DatahubTools.GetFileTypeIcon(result.Name)"></i>
                                        </Icon>
                                    </FileItem>
                                }                                
                            }
                        }


                    </div>

                    <div class="item-details">
                        <div class="details-sticky">
                            <div class="details-container">
                                @if (SelectedFile == null)
                                {
                                    <MudText>@Localizer["Select a file to view its details."]</MudText>
                                }
                                else
                                {
                                    var file = _files.FirstOrDefault(f => f.name.Equals(SelectedFile.Name, StringComparison.OrdinalIgnoreCase));
                                    if (file != null)
                                    {
                                        file.folderpath = @SelectedFile.Path;
                                        <FileProperties @key=@SelectedFile.Name
                                                        ProjectId=@ProjectId
                                                        File=@file
                                                        FolderName=@SelectedFile.Path
                                                        Readonly="true" />
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </CascadingValue>
    }
    </MudStack>

    @code {
    [Parameter] public List<FileSearchResult> SearchResults { get; set; }
    [Parameter] public CloudStorageContainer Container { get; set; }
    [Parameter] public int? ProjectId { get; set; }

    public StorageMetadata StorageAccountMetadata { get; set; }

    private FileSearchResult SelectedFile { get; set; }
    private List<FileMetaData> _files = new();

    private string _continuationToken;
    private bool IsLoading { get; set; } = true; // Default to true to show the loading indicator initially
    private int? SelectedFileIndex { get; set; }

    private ICloudStorageManager StorageManager => Container?.StorageManager;
    private string ContainerName => Container?.Name;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
        {
            if (StorageManager != null)
            {
                StorageAccountMetadata = await StorageManager.GetStorageMetadataAsync(ContainerName);
                var dfsPage = await StorageManager.GetDfsPagesAsync(Container.Name, "", _continuationToken);

                _continuationToken = dfsPage.ContinuationToken;
                _files = dfsPage.Files;
                StateHasChanged();
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        IsLoading = true; // Start loading
        await base.OnParametersSetAsync();

        if (SearchResults != null && SearchResults.Any())
        {
            SelectedFile = SearchResults.First();
        }
        else
        {
            SelectedFile = null;
        }

        IsLoading = false; // Stop loading
    }

    private void HandleFileSelectionClick(FileSearchResult file)
    {
        SelectedFile = file;
        StateHasChanged();
    }

    private string FormatSize(long size)
    {
        if (size <= 0) return "Unknown"; // Handle 0 size
        if (size < 1024) return $"{size} B";
        if (size < 1024 * 1024) return $"{size / 1024.0:F2} KB";
        if (size < 1024 * 1024 * 1024) return $"{size / (1024.0 * 1024):F2} MB";
        return $"{size / (1024.0 * 1024 * 1024):F2} GB";
    }

    private string FormatTimestamp(DateTime? timestamp)
    {
        if (timestamp == null || timestamp == default) return "Unknown"; // Handle invalid timestamps
        return timestamp.Value.ToString("r"); // Format as RFC1123
    }
}
