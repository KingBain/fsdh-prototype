@using ByteSizeLib
@using Datahub.Core.Model
@implements IAsyncDisposable
@inject IJSRuntime _jsRuntime

<div
    @ref="_fileItemElement"
    draggable="true"
    data-type="@(Folder ? "folder" : "file")"
    data-name="@Name"
    class="file-item @(Highlighted ? "highlight" : "")"
    @onclick="OnClick"
    @ondblclick="OnDblClick">
    @if (Folder)
    {
        <span></span>
    }
    else
    {
        <span class="file-selection-icon" @onclick="OnSelectionClick" @onclick:stopPropagation="true">
            <i class="far fa-circle unchecked"></i>
            <i class="far fa-check-circle suggest"></i>
            <i class="fas fa-check-circle checked"></i>
        </span>
    }
    <MudText class="file-item-name" title="@Name">
        <span class="file-item-icon">
            @if (Icon != null)
            {
                @Icon
            }
            else
            {
                <i class="fas fa-file"></i>
            }
        </span>
        @Name
    </MudText>
    <MudText class="file-item-size">@(ByteSize ?? "")</MudText>
    <MudText class="file-item-modified" title="@(Modified?.ToString("F") ?? "")">@(Modified?.ToString("d") ?? "")</MudText>
    <MudText class="file-item-scan-status">
        @if (ScanStatus.HasValue)
        {
            @switch (ScanStatus.Value)
            {
                case FileScanStatus.ScanInProgress:
                    <MudChip T="string" Color="Color.Info" Size="MudBlazor.Size.Medium" Class="scan-status-chip">
                        <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" />
                        @Localizer["Scanning"]
                    </MudChip>
                    break;
                case FileScanStatus.Succeeded:
                    <MudChip T="string" Color="Color.Success" Size="MudBlazor.Size.Medium" Icon="fas fa-check" Class="scan-status-chip">
                        @Localizer["Succeeded"]
                    </MudChip>
                    break;
                case FileScanStatus.Error:
                    <MudChip T="string" Color="Color.Error" Size="MudBlazor.Size.Medium" Icon="fas fa-exclamation-triangle" Class="scan-status-chip"
                             OnClick="@(() => OnScanErrorClick.InvokeAsync())" Style="cursor: pointer;">
                        @Localizer["Error"]
                    </MudChip>
                    break;
            }
        }
    </MudText>
</div>

@code {

    [CascadingParameter(Name = "FilterValue")]
    public string FilterValue { get; set; }

    [Parameter]
    public bool Folder { get; set; }

    [Parameter]
    public bool Highlighted { get; set; }

    [Parameter]
    public string Name { get; set; }

    [Parameter]
    public RenderFragment Icon { get; set; }

    [Parameter]
    public string Size { get; set; }

    [Parameter]
    public DateTime? Modified { get; set; }

    [Parameter]
    public FileScanStatus? ScanStatus { get; set; }

    [Parameter]
    public EventCallback OnScanErrorClick { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnSelectionClick { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnDblClick { get; set; }

    private string ByteSize
    {
        get
        {
            if (Folder)
            {
                return "";
            }

            if (long.TryParse(Size, out var sizeInBytes))
            {
                return ByteSizeLib.ByteSize.FromBytes(sizeInBytes).ToString();
            }

            return Size ?? "";
        }
    }

    private IJSObjectReference _module;
    private ElementReference _fileItemElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
        {
            try
            {
                _module = await _jsRuntime.InvokeAsync<IJSObjectReference>("import", "./Pages/Workspace/Storage/FileItem.razor.js");
                await _module.InvokeVoidAsync("attachDragEvents", _fileItemElement);
            }
            catch (Exception)
            {
                // ignored - module might not be available in all contexts
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module != null)
            {
                await _module.DisposeAsync();
            }
        }
        catch (Exception)
        {
            // ignored
        }
    }
}
