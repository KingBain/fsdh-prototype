@* CbrBudgetAllocationDonut *@

@using ApexCharts
@using Datahub.Application.Services.Cost
@using Datahub.Core.Model.Projects
@using Ut = BudgetCostReportUtils

<MudContainer >
    <h2 class="sr-only">
        @Localizer["A donut chart showing the budget allocation for the workspaces in this CBR. An accessible description is provided below the chart."]
    </h2>
    <ApexChart TItem="DailyServiceCost" 
               Title="@Title" 
               Options="@_options">
        <ApexPointSeries TItem="DailyServiceCost"
                         Name="@Localizer["Budget allocations"]"
                         Items="@BudgetAllocations"
                         XValue="@(c => string.IsNullOrEmpty(c.Source)? Localizer["Unallocated"] : c.Source)"
                         YValue="@(c => decimal.Round(c.Amount, 2))"
                         SeriesType="SeriesType.Donut"
                         ShowDataLabels="true" />
    </ApexChart>
    <p class="sr-only">
        @Localizer["Budget allocation for the workspaces in this CBR. A detailed table is provided below the charts."]

        @foreach(var allocation in BudgetAllocations)
        {
            @if (string.IsNullOrEmpty(allocation.Source))
            {
                @Localizer["{0} is unallocated.", Ut.DisplayDollar(allocation.Amount)]
            }
            else
            {
                @Localizer["Budget for workspace {0} is {1}.", allocation.Source, Ut.DisplayDollar(allocation.Amount)]
            }
        }

        @Localizer["Overall, {0} of the total CBR budget of {1} has been allocated to workspaces.", 
            Ut.DisplayDollar(Ut.GetTotalNonBlankAmount(BudgetAllocations)),
            Ut.DisplayDollar(Ut.GetTotalAmount(BudgetAllocations))]
        
    </p>

</MudContainer>


@code {
    [Parameter] public string Title { get; set; }
    [Parameter, EditorRequired] public List<DailyServiceCost> BudgetAllocations { get; set; }

    private ApexChartOptions<DailyServiceCost> _options = new();

    private void DefineOptions()
    {
        _options.Legend = new()
            {
                Position = LegendPosition.Bottom
            };
        _options.DataLabels = new()
            {
                Style = new()
                {
                    Colors = ["#000"],
                    FontSize = "16px"
                },
                DropShadow = new()
                {
                    Enabled = false
                }
            };
        _options.PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    Donut = new PlotOptionsDonut
                    {
                        Labels = new DonutLabels
                        {
                            Total = new DonutLabelTotal
                            {
                                FontSize = "24px",
                                Label = Localizer["Total"],
                                Color = "#000",
                                Formatter = "function(val) {" +
                                            "var arr = val.globals.seriesTotals;" +
                                            "var sum = arr.reduce(function(a, b) { return a + b}, 0);" +
                                            "return '$'+sum.toFixed(2);" +
                                            "}"
                            },
                            Value = new DonutLabelValue
                            {
                                FontSize = "24px",
                                Color = "#000",
                                Formatter = "function(val) {" +
                                            "return '$'+val;" +
                                            "}"
                            },
                            Name = new DonutLabelName
                            {
                                Color = "#000"
                            }
                        },
                        Size = "70%",
                    },
                    DataLabels = new PieDataLabels
                    {
                        MinAngleToShowLabel = 3
                    }
                }
            };
        _options.Tooltip = new Tooltip
            {
                FillSeriesColor = false,
                Y = new TooltipY
                {
                    Formatter = "function(val) { return '$'+val; }"
                },
                Theme = Mode.Light,
            };
        _options.Yaxis = new List<YAxis>();
        _options.Yaxis.Add(new YAxis
            {
                Title = new AxisTitle { Text = Localizer["Amount ($CAD)"].ToString() },
                DecimalsInFloat = 2,
                Max = BudgetAllocations.Max(c => c.Amount)
            });
    }

    protected override void OnParametersSet()
    {
        DefineOptions();
        base.OnParametersSet();
    }

}
