    // TODO move this to a util class or similar
    private System.Version ParseVersionTag(string versionTag)
    {
        var versionTagNumeric = versionTag?.TrimStart('v');
        if (versionTagNumeric is not null && System.Version.TryParse(versionTagNumeric, out var version))
        {
            return version;
        }
        else
        {
            return new(0,0,0);
        }
    }

    private async Task<System.Version> DetermineWorkspaceVersion(Datahub_Project workspace)
    {
        //TODO: workspaces shouldn't have "latest" version string, however in dev some still do.
        // If we can guarantee that all workspaces have a proper version string, we can remove this check.
        if (workspace.Version == TerraformWorkspace.LatestVersionString)
        {
            var latestVersionTag = await WorkspaceVersionService.GetLatestVersionAsync();
            return ParseVersionTag(latestVersionTag);
        }

        return ParseVersionTag(workspace.Version);
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        await using var context = await ContextFactory.CreateDbContextAsync();
        _viewedPortalUser = await GetViewedPortalUserAsync();
        _workspace = await context.Projects
            .AsNoTracking()
            .Include(w => w.Resources)
            .Include(w => w.Credits)
            .FirstAsync(w => w.Project_Acronym_CD == WorkspaceAcronym);
        _workspaceDefinition = await ResourceMessagingService.GetWorkspaceDefinition(_workspace.Project_Acronym_CD, _viewedPortalUser.Email);
        _workspaceCosts.Spent = (decimal)(_workspace.Credits?.Current ?? 0);
        _workspaceCosts.Budget = _workspace.Project_Budget ?? 100;
        _workspaceCosts.Monthly = (decimal)(_workspace.Credits?.YesterdayCredits ?? 0) * 30;
        _disableOverBudget = DatahubPortalConfiguration.ToolboxConfig.DisableOnOverBudget && _workspaceCosts.Spent > _workspaceCosts.Budget;
        _disableActiveRequest = DatahubPortalConfiguration.ToolboxConfig.DisableOnActiveRequest && _workspace.Resources.Any(r => TerraformStatus.RequestedOrInProcessOf(r.Status));
        _disableSubmissionDelays = DatahubPortalConfiguration.ToolboxConfig.DisableSubmissionDelays;
        _disableSubmissions = DatahubPortalConfiguration.ToolboxConfig.DisableSubmissions;
        // TODO: Update this piece of code once the metadata is filled in via GC Hosting

        _workspaceVersion = await DetermineWorkspaceVersion(_workspace);

        PopulateCatalog();
        Log("Beginning transaction");
        _transactions = ToolboxService.BeginTransaction();
        _initializing = false;
        await InvokeAsync(StateHasChanged);
    }

