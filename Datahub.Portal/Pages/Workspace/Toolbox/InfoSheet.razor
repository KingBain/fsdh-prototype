<MudDialog Style="width: 50%;">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center">
            <DHIcon Icon="@Icon"/>
            <MudText Typo="Typo.h2">@Title</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Class="pb-8" id=@WorkspaceToolboxPage.ElementId([Id, InfoSheetId])>
            <MudText Typo="Typo.h3">@Localizer["Information"]</MudText>
            <MudText Typo="Typo.body1"
                     Style="font-style: italic">@Localizer["Availability: {0}, Category: {1}", Availability, Category]</MudText>
            <MudText>@Description</MudText>
            @if (Dependencies != null && Dependencies.Any())
            {
                <MudText Typo="Typo.h3">@Localizer["Dependencies"]</MudText>
                <MudStack Row Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="4">
                    @foreach (var (icon, label) in Dependencies)
                    {
                        <MudPaper Outlined Elevation="0" Class="pa-3">
                            <MudStack Row AlignItems="AlignItems.Center">
                                <DHIcon Icon=@icon/>
                                <MudText>@label</MudText>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
            <MudText Typo="Typo.h3">@Localizer["Cost & usage"]</MudText>
            <MudText
                Typo="Typo.body1">@Localizer["{0} is currently used in {1} workspaces.", Title, Instances]</MudText>
            <MudText>
                @CostInformation
            </MudText>
            @if (AdditionalLinks.Length != 0)
            {
                <MudText Typo="Typo.h3">@Localizer["Read more"]</MudText>
                <MudList T="MudLink" >
                    @foreach (var link in AdditionalLinks)
                    {
                        <MudListItem>
                            <MudLink Href="@link.URL" Target="_blank">@link.Text</MudLink>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudStack>
    </DialogContent>
</MudDialog>

@code {
    [Parameter] public string Icon { get; set; }
    [Parameter] public string Title { get; set; }
    [Parameter] public string Category { get; set; }
    [Parameter] public string Description { get; set; }
    [Parameter] public (string Icon, string Name)[] Dependencies { get; set; }
    [Parameter] public int Instances { get; set; }
    [Parameter] public string Availability { get; set; }
    [Parameter] public string CostInformation { get; set; }
    [Parameter] public (string Text, string URL)[] AdditionalLinks { get; set; }
    [Parameter] public string Id { get; set; }
    public static string InfoSheetId => "info-sheet";
}
