@using Datahub.Application.Services.ReverseProxy
@using Datahub.Core.Data
@using Datahub.Portal.Components.Sidebar
@using Microsoft.AspNetCore.Components.Authorization

@inject IDbContextFactory<DatahubProjectDBContext> _dbContextFactory
@inject NavigationManager _navigationManager
@inject IReverseProxyConfigService _reverseProxyConfigService

@attribute [Route(PageRoutes.WorkspaceWebAppShare)]
@attribute [ExternalUserPage]

<EnvironmentTopBar SecurityLevel="@_dataSensitivity" />

<PageTitle>
  @Localizer["{0} - Workspace - Federal Science DataHub", WorkspaceAcronymParam ?? ""]
</PageTitle>

<DHSidebarDrawer>
  <WorkspaceSidebar WorkspaceAcronym="@WorkspaceAcronymParam" />
</DHSidebarDrawer>

<MudItem xs="12" sm="12">

  <WorkspaceInfo WorkspaceAcronym="@WorkspaceAcronymParam" />
  @if (!isAvailable)
  {
    <MudText>
      @Localizer["This web application has not been configured yet."]
    </MudText>
    <DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.WorkspaceAdmin" ProjectAcronym="@WorkspaceAcronymParam">
      <MudText Class="mt-3">
        @Localizer["Workspace admins can configure the web app using the link below."]
      </MudText>
      <DHButton Href=@($"/{PageRoutes.WorkspacePrefix}/{WorkspaceAcronymParam}/{_reverseProxyConfigService.WebAppPrefix}")
                Color="Color.Primary"
                Variant="@Variant.Text"
                EndIcon="@Icons.Material.Outlined.KeyboardDoubleArrowRight"
                Underline>
        @Localizer["View Web App configuration"]
      </DHButton>
    </DatahubAuthView>
  }
  else
  {
    <MudStack Row="true">
      <MudText Typo="Typo.h3">
        @Localizer["Web Application hosted by FSDH"]
      </MudText>
      @if (isDisclaimerAccepted)
      {
        <MudButton Href="@_reverseProxyConfigService.BuildWebAppURL(WorkspaceAcronymParam)" Target="_blank"
                   EndIcon="@Icons.Material.Filled.Launch" Variant="Variant.Filled"
                   Color="Color.Primary">@Localizer["Open in new window"]</MudButton>
                  <DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.WorkspaceAdmin" ProjectAcronym="@WorkspaceAcronymParam">
                    <DHButton Href=@($"/{PageRoutes.WorkspacePrefix}/{WorkspaceAcronymParam}/{_reverseProxyConfigService.WebAppPrefix}")
                              Color="Color.Primary"
                              Variant="@Variant.Text"
                              EndIcon="@Icons.Material.Outlined.KeyboardDoubleArrowRight"
                              Underline>
                      @Localizer["View Web App configuration"]
                    </DHButton>
                  </DatahubAuthView>
                }
    </MudStack>
  }
</MudItem>
@if (isDisclaimerAccepted)
{
  <DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.WorkspaceGuest" ProjectAcronym="@WorkspaceAcronymParam">
    <Authorized>
      <MudGrid Class="mt-4">

        @if (isAvailable)
        {
          <MudItem xs="12">
            <iframe src="@_reverseProxyConfigService.BuildWebAppURL(WorkspaceAcronymParam)"
                    style="height: 70vh; border: none;" title="@Localizer["Web Application hosted by FSDH"]"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>
          </MudItem>
        }

      </MudGrid>
    </Authorized>
    <NotAuthorized>
      <NotAuthorizedMessage />
    </NotAuthorized>
  </DatahubAuthView>
}
else if (isAvailable)
{
  <AcknowledgementConfirmation OnAccepted="ApproveWebAppTC"
                               MarkdownPathEn="/UserGuide/Acknowledgements/WebAppTC.md"
                               MarkdownPathFr="/fr/UserGuide/Acknowledgements/WebAppTC-fr.md"
                               ButtonText=@Localizer["Accept Web Application Terms"] />
}


@code {

  [CascadingParameter]
  private Task<AuthenticationState> AuthenticationStateTask { get; set; } = null!;

  [Parameter] public string WorkspaceAcronymParam { get; set; }

  private bool isAvailable = false;

  private bool isDisclaimerAccepted = false;

  private Datahub.Metadata.Model.ClassificationType _dataSensitivity;

  [SupplyParameterFromQuery(Name = "d")] public string DisclaimerAccepted { get; set; }

  protected override async Task OnInitializedAsync()
  {
    var authState = await AuthenticationStateTask;
    var user = authState.User;
    if (user.IsInRole(RoleConstants.EXTERNAL_LOGIN)
        && (string.IsNullOrWhiteSpace(WorkspaceAcronymParam)
            || !user.IsInRole($"{WorkspaceAcronymParam}{RoleConstants.WEBAPP_SUFFIX}")))
    {
      _navigationManager.NavigateTo(PageRoutes.AccessDenied, forceLoad: true);
      return;
    }

    await using var ctx = await _dbContextFactory.CreateDbContextAsync();
    var workspace = await ctx.Projects
        .Include(x => x.Resources)
        .FirstOrDefaultAsync(x => x.Project_Acronym_CD == WorkspaceAcronymParam);
    var appConfiguration = TerraformVariableExtraction.ExtractAppServiceConfiguration(workspace);
    _dataSensitivity = workspace.Data_Sensitivity;
    isAvailable = workspace is not null && !(string.IsNullOrWhiteSpace(appConfiguration?.Framework) && string.IsNullOrWhiteSpace(appConfiguration?.GitRepo) && string.IsNullOrWhiteSpace(appConfiguration?.ComposePath));
    if (DisclaimerAccepted == "1")
    {
      isDisclaimerAccepted = true;
    }

    StateHasChanged();
  }

  private async Task ApproveWebAppTC()
  {
    // Construct the new URL with the d=1 query parameter
    var newUrl = $"{_navigationManager.Uri.Split('?')[0]}?d=1";

    // Redirect the user to the same page with d=1
    _navigationManager.NavigateTo(newUrl);
    isDisclaimerAccepted = true;
    await InvokeAsync(StateHasChanged);
  }

}
