@using Datahub.Application.Services
@using Datahub.Application.Services.Publishing
@using Datahub.Core.Data
@using Datahub.Core.Model.Projects
@using Datahub.Shared
@using Microsoft.AspNetCore.Components.Authorization
@inject DatahubPortalConfiguration _config
@inject IOpenDataPublishingService _publishingService
@inject IDialogService _dialogService
@inject IUserInformationService _userInformationService

@if (!_isExternalUser || _canAccessExternalStorage)
{
<MudPaper Outlined Class="pa-4">
    <MudStack>
        <MudStack Row AlignItems="AlignItems.Center">
            <DHIcon Icon="fa-light fa-hard-drive" Size="Size.Medium" />
            <MudText Typo="Typo.h3">@Localizer["Workspace Storage"]</MudText>
        </MudStack>

        <MudText>
            @Localizer["Access the storage accounts for the workspace to upload, download and share datasets with all workspace members. Datasets in workspace storage may also be published on Open Data."]
        </MudText>
        <MudElement HtmlTag="div">
            @if (ProjectResource.Status == TerraformStatus.Completed)
            {
            <MudStack Row>
                <DHButton
                    Href="@GetStorageUrl()"
                    Color="Color.Primary"
                    Variant="@Variant.Text"
                    EndIcon="@Icons.Material.Outlined.KeyboardDoubleArrowRight" Underline>
                    @Localizer["View storage"]
                </DHButton>
                
                @if (_config.CkanConfiguration.IsFeatureEnabled)
                {
                    @if (_isPublishingBlockedForWorkspace)
                    {
                        <DHButton 
                            OnClick="@ShowPublishingBlockedDialog"
                            Color="Color.Primary"
                            Variant="@Variant.Text"
                            EndIcon="@Icons.Material.Outlined.KeyboardDoubleArrowRight" Underline>
                            @Localizer["Open Publishing Dashboard"]
                        </DHButton>
                    }
                    else
                    {
                        <DHButton 
                            Href="@($"/{PageRoutes.WorkspacePrefix}/{WorkspaceAcronym}/{WorkspaceSidebar.SectionViews.Publishing}")"
                            Color="Color.Primary"
                            Variant="@Variant.Text"
                            EndIcon="@Icons.Material.Outlined.KeyboardDoubleArrowRight" Underline>
                            @Localizer["Open Publishing Dashboard"]
                        </DHButton>
                    }
                }
            </MudStack>
            }
            else
            {
                <ToolBeingProvisionedButton />
            }
        </MudElement>
    </MudStack>
</MudPaper>
}

@code {

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = null!;

    private bool _isPublishingBlockedForWorkspace = false;
    private bool _isExternalUser = false;
    private bool _canAccessExternalStorage = false;

    [Parameter]
    [EditorRequired]
    public Project_Resources2 ProjectResource { get; set; }

    [Parameter]
    [EditorRequired]
    public string WorkspaceAcronym { get; set; }

    [Parameter]
    [EditorRequired]
    public Datahub_Project Project { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authState = await AuthenticationStateTask;
        var user = authState.User;

        _isExternalUser = await _userInformationService.IsExternalUser();
        _canAccessExternalStorage = !string.IsNullOrWhiteSpace(WorkspaceAcronym)
            && user.IsInRole($"{WorkspaceAcronym}{RoleConstants.STORAGE_SUFFIX}");
        _isPublishingBlockedForWorkspace = await _publishingService.IsPublishingBlockedForWorkspaceAsync(WorkspaceAcronym);
    }

    private string GetStorageUrl()
    {
        return _isExternalUser
            ? $"/{PageRoutes.WorkspacePrefix}/{WorkspaceAcronym}/{PageRoutes.WorkspaceExternalStoragePrefix}"
            : $"/{PageRoutes.WorkspacePrefix}/{WorkspaceAcronym}/{WorkspaceSidebar.SectionViews.Storage}";
    }

    private async Task ShowPublishingBlockedDialog()
    {
        await _dialogService.ShowMessageBox(
            Localizer["Publishing Disabled"],
            Localizer["Publishing has been disabled for this workspace by the administrator."],
            yesText: Localizer["OK"]);
    }

}