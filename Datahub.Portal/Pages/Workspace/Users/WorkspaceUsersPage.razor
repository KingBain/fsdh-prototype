@using Datahub.Application.Services
@using Datahub.Core.Model.Projects
@using MudBlazor.Utilities
@using Datahub.Portal.Components.User
@using Datahub.Application.Commands
@using Datahub.Application.Services.UserManagement
@using Datahub.Core.Data
@using Datahub.Core.Model.Users
@using Datahub.Portal.Pages.Tools.LockedUsers


@inject IUserInformationService _userInformationService
@inject IProjectUserManagementService _projectUserManagementService
@inject ILockedUserManagementService _lockedUserManagementService
@inject IDialogService _dialogService
@inject ISnackbar _snackbar
@inject IDbContextFactory<DatahubProjectDBContext> _dbContextFactory

@if (_updateInProgress)
{
  <DHLoadingInitializer />
}

<DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.WorkspaceAdmin" ProjectAcronym="@WorkspaceAcronym" ElevatedWorkspaceAccessEnabled="@ElevatedWorkspaceAccessEnabled">
  @if (_usersToAdd.Any() || _usersToUpdate.Any())
  {
    <MudStack Class="sticky-stack">
      <MudStack Row AlignItems="AlignItems.Center">
        <MudElement>
          <DHButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@(_updateInProgress || _validationErrorMessage is not null)" OnClick="SaveChanges" Tag=@("SaveChanges")>
            @Localizer["Save Changes"]
          </DHButton>
        </MudElement>
        @if (_validationErrorMessage is null)
        {
          <MudAlert Severity="Severity.Info" Class="my-3">
            <MudText Typo="Typo.body2">@Localizer["You have unsaved changes. Please save them before leaving this page."]</MudText>
          </MudAlert>
        }
        else
        {
          <MudAlert Severity="Severity.Error" Class="my-3">
            <MudText Typo="Typo.body2">@_validationErrorMessage</MudText>
          </MudAlert>
        }
      </MudStack>
    </MudStack>
  }
</DatahubAuthView>

<MudStack>
  <DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.WorkspaceAdmin" ProjectAcronym="@WorkspaceAcronym" ElevatedWorkspaceAccessEnabled="@ElevatedWorkspaceAccessEnabled">
    <MudStack>
      @if (_usersToAdd.Any())
      {
        <MudStack>
          <MudText Typo="Typo.h2">
            @Localizer["Invitations"]
          </MudText>
          <MudText Typo="Typo.body1">
            @Localizer["You will be inviting the following users to your workspace"]
          </MudText>
          @foreach (var userToBeAdded in _usersToAdd)
          {
            <MudPaper Elevation="0" Outlined Class="py-4 px-6">
              <MudGrid>
                <MudItem xs="4">
                  <MudStack Row AlignItems="AlignItems.Center">
                    @if (userToBeAdded.GraphGuid == ProjectUserAddEntraUserCommand.NEW_USER_GUID)
                    {
                      <MudAvatar>
                        <DHIcon Icon="@Icons.Material.Outlined.PersonAdd" />
                      </MudAvatar>
                    }
                    else
                    {
                      <UserAvatar ViewedUser="@userToBeAdded.PortalUser" Size="@Size.Medium" />
                    }
                    <MudText>
                      @if (userToBeAdded.GraphGuid == ProjectUserAddEntraUserCommand.NEW_USER_GUID)
                      {
                        @userToBeAdded.Email
                      }
                      else
                      {
                        @userToBeAdded.DisplayName
                      }
                    </MudText>
                  </MudStack>
                </MudItem>

                <MudItem xs="4">
                  <MudStack Row AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.body2">
                      @Localizer["will be added as a"]
                    </MudText>
                    <ProjectMembersRoleSelect InitialValue="@userToBeAdded.RoleId" OnRoleChanged="@(newRoleId => UpdateProjectMemberRoleCommand(userToBeAdded, newRoleId))" />
                  </MudStack>
                </MudItem>

              </MudGrid>
            </MudPaper>
          }
        </MudStack>
      }
    </MudStack>
  </DatahubAuthView>
  @if (_loading)
  {
    <MudProgressCircular Indeterminate Color="Color.Primary" />
    <MudText Typo="Typo.body2" Class="mt-2">@Localizer["Loading workspace members..."]</MudText>
  }
  else
  {
    <MudStack Row Class="mt-6 mb-4">
      <DHMainContentTitle Title="@Localizer["Workspace Members"]" />
      <MudSpacer />
      <DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.WorkspaceAdmin" ProjectAcronym="@WorkspaceAcronym" ElevatedWorkspaceAccessEnabled="@ElevatedWorkspaceAccessEnabled">
        <DHButton Variant="Variant.Outlined" Color="Color.Primary" EndIcon="@Icons.Material.Outlined.PersonAdd" OnClick="OpenDialog">
          @Localizer["Invite New User"]
        </DHButton>
      </DatahubAuthView>
    </MudStack>
    <MudTable Items="@_projectUsers" Striped Filter="@(new Func<UserRoleLinks, bool>(CombinedFilter))">
      <ToolBarContent>
        <MudStack Row AlignItems="AlignItems.Center">
          <MudTabs Elevation="0" Rounded>
            <MudTabPanel Text="@Localizer["All"]"
                         BadgeData="@_allCount"
                         BadgeColor="Color.Transparent"
                         Style="@_tabStyle"
                         OnClick="@(() => ProjectMemberRoleFilter(null))" />
            <MudTabPanel Text="@Localizer["Workspace Leads"]"
                         BadgeData="@_workspaceLeadCount"
                         BadgeColor="Color.Transparent"
                         Style="@_tabStyle"
                         OnClick="@(() => ProjectMemberRoleFilter((int)Project_Role.RoleNames.WorkspaceLead))"
                         Disabled="@(_workspaceLeadCount == 0)" />
            <MudTabPanel Text="@Localizer["Admins"]"
                         BadgeData="@_adminCount"
                         BadgeColor="Color.Transparent"
                         Style="@_tabStyle"
                         OnClick="@(() => ProjectMemberRoleFilter((int)Project_Role.RoleNames.Admin))"
                         Disabled="@(_adminCount == 0)" />
            <MudTabPanel Text="@Localizer["Collaborators"]"
                         BadgeData="@_contributorCount"
                         BadgeColor="Color.Transparent"
                         Style="@_tabStyle"
                         OnClick="@(() => ProjectMemberRoleFilter((int)Project_Role.RoleNames.Collaborator))"
                         Disabled="@(_contributorCount == 0)" />
            <MudTabPanel Text="@Localizer["Guests"]"
                         BadgeData="@_guestCount"
                         BadgeColor="Color.Transparent"
                         Style="@_tabStyle"
                         OnClick="@(() => ProjectMemberRoleFilter((int)Project_Role.RoleNames.Guest))"
                         Disabled="@(_guestCount == 0)" />
          </MudTabs>
          <MudStack AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="_filterString"
                          Placeholder="@Localizer["Search"]"
                          Immediate
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Label="@Localizer["Search"]"
                          IconSize="Size.Medium" />
          </MudStack>
        </MudStack>
      </ToolBarContent>

      <HeaderContent>
        <MudTh>
          <MudTableSortLabel SortBy="@(new Func<UserRoleLinks, object>(x => x?.PortalUser?.DisplayName))" InitialDirection="SortDirection.Ascending">
            @Localizer["Account"]
          </MudTableSortLabel>
        </MudTh>
        <MudTh>
          <MudTableSortLabel SortBy="@(new Func<UserRoleLinks, object>(x => x?.PortalUser?.Email))">
            @Localizer["Email"]
          </MudTableSortLabel>
        </MudTh>
        <MudTh>@Localizer["Role"]</MudTh>
        <MudTh>@Localizer["Data Steward"]</MudTh>
        <MudTh>
          <MudTableSortLabel SortBy="@(new Func<UserRoleLinks, object>(x => x?.Approved_DT))">
            @Localizer["Added to Workspace"]
          </MudTableSortLabel>
        </MudTh>
        <MudTh>@Localizer["Status"]</MudTh>
        <MudTh></MudTh>
      </HeaderContent>

      <RowTemplate Context="rowContext">
        <MudTd Style="@(IsModified(rowContext) ? _modifiedCellStyle : string.Empty)">
          <MudStack Row AlignItems="AlignItems.Center">
            <UserAvatar ViewedUser="@rowContext.PortalUser" Size="@Size.Medium" />
            <MudText>
              @rowContext.PortalUser?.DisplayName
            </MudText>
          </MudStack>
        </MudTd>
        <MudTd Style="@(IsModified(rowContext) ? _modifiedCellStyle : string.Empty)">
          @rowContext.PortalUser.Email
        </MudTd>
        <MudTd Style="@(IsModified(rowContext) ? _modifiedCellStyle : string.Empty)">
          @if (rowContext.Role.Id == (int)Project_Role.RoleNames.DisabledUser)
          {
            <MudText>@Localizer[rowContext.Role.Name]</MudText>
          }
          else
          {
            <DatahubAuthView AuthLevel="@GetAuthLevel(rowContext)" ProjectAcronym="@WorkspaceAcronym" ElevatedWorkspaceAccessEnabled="@ElevatedWorkspaceAccessEnabled">
              <Authorized>
                @{
                  var updateCommand = _usersToUpdate.FirstOrDefault(x => x.ProjectUser.PortalUser.Id == rowContext.PortalUser.Id);
                }
                <ProjectMembersRoleSelect InitialValue="@(updateCommand?.NewRoleId ?? rowContext.RoleId ?? 0)" OnRoleChanged="@(newRoleId => UpdateProjectMemberRole(rowContext, newRoleId))" />
              </Authorized>
              <NotAuthorized>
                <MudText>@Localizer[rowContext.Role.Name]</MudText>
              </NotAuthorized>
            </DatahubAuthView>
          }
        </MudTd>
        <MudTd Style="@(IsModified(rowContext) ? _modifiedCellStyle : string.Empty)">
          <MudCheckBox T="bool" Label=@Localizer["Data Steward"]
                       Value="rowContext.IsDataSteward"
                       Tag=@("DataSteward")
                       Disabled=@(IsDataStewardCheckboxDisabled(rowContext))
                       ValueChanged="@(newValue => ChangeDataStewardFlag(rowContext, newValue))" />
        </MudTd>
        <MudTd Style="@(IsModified(rowContext) ? _modifiedCellStyle : string.Empty)">
          @if (rowContext.Approved_DT != null)
          {
            @rowContext.Approved_DT.Value.ToString("yyyy-MM-dd")
          }
        </MudTd>
        <MudTd Style="@(IsModified(rowContext) ? _modifiedCellStyle : string.Empty)">
          @if (TryGetLockedUser(rowContext, out var lockStatus))
          {
            <MudStack>
              <MudText Color="Color.Warning">
                @Localizer["Account Locked"]
              </MudText>
              @if (lockStatus != null)
              {
                <MudText Typo="Typo.caption">
                  @Localizer["Locked on"]: @lockStatus.LockedDate?.ToString("yyyy-MM-dd HH:mm")
                </MudText>
                <DHButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(async () => await OpenUploadEvidenceDialog(rowContext.PortalUser))">
                  @Localizer["Upload Evidence"]
                </DHButton>
              }
            </MudStack>
          }
          else
          {
            <MudText Color="Color.Success">
              @Localizer["Active"]
            </MudText>
          }
        </MudTd>
        <MudTd Style="@(IsModified(rowContext) ? _modifiedCellStyle : string.Empty)">
          <UserViewProfileIconButton ViewedUser="@rowContext.PortalUser" />
        </MudTd>
      </RowTemplate>


      <NoRecordsContent>
        <MudText>@Localizer["There are no users matching the current filter."]</MudText>
      </NoRecordsContent>

      <PagerContent>
        <MudTablePager RowsPerPageString="@Localizer["Rows per page:"]"
                       InfoFormat="@("{first_item}-{last_item} " + Localizer["of"] + " {all_items}")" />
      </PagerContent>
    </MudTable>
  }
</MudStack>

@code {

  [Parameter] public string WorkspaceAcronym { get; set; }
  [Parameter] public bool ElevatedWorkspaceAccessEnabled { get; set; } = false;

  private string _filterString = null;
  private string _tabStyle;

  private bool _updateInProgress;
  private bool _loading = true;

  //
  private int _workspaceLeadCount => _projectUsers?.Count(x => x.Role?.Id == (int)Project_Role.RoleNames.WorkspaceLead) ?? 0;
  private int _adminCount => _projectUsers?.Count(x => x.Role?.Id == (int)Project_Role.RoleNames.Admin) ?? 0;
  private int _contributorCount => _projectUsers?.Count(x => x.Role?.Id == (int)Project_Role.RoleNames.Collaborator) ?? 0;
  private int _guestCount => _projectUsers?.Count(x => x.Role?.Id == (int)Project_Role.RoleNames.Guest) ?? 0;
  private int _allCount => _projectUsers?.Count(x => x.Role?.Id != (int)Project_Role.RoleNames.Removed) ?? 0;

  private List<UserRoleLinks> _projectUsers;
  private List<WorkspaceUserInfo> _originalUserInfo = new();
  private Dictionary<int, UserLockStatus> _lockedUsersByPortalUserId = new();
  private int? _workspaceId;

  private int? _currentRoleFilter = default;

  private readonly List<ProjectUserAddEntraUserCommand> _usersToAdd = new();
  private readonly List<ProjectUserUpdateCommand> _usersToUpdate = new();

  private string _modifiedCellStyle;

  private string? _validationErrorMessage = null;

}
