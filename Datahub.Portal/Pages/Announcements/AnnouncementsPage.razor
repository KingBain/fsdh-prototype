@using Datahub.Core.Model.Announcements
@using Datahub.Application.Services.Announcements


@inject IAnnouncementService _announcementService

@attribute [Route(PageRoutes.News)]
@attribute [Route(PageRoutes.News_FR)]

<PageTitle>
    @Localizer["Announcements - Federal Science DataHub"]
</PageTitle>

<DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.Authenticated">
    <MudStack Spacing="6">
        <MudStack Row>
            <DHMainContentTitle Title="@Localizer["Announcements"]" />
            <MudSpacer/>
            <DatahubAuthView AuthLevel="DatahubAuthView.AuthLevels.DatahubSupport">
                <DHButton Variant="Variant.Outlined" Color="Color.Primary" Href="/announcements/edit/new">@Localizer["Create a new Announcement"]</DHButton>
            </DatahubAuthView>
        </MudStack>

        @if (_announcements.Any())
        {
            <MudStack>
                @for (int i = 0; i < _announcements.Count; i++)
                {
                    var announcement = _announcements[i];
                    var authLevel = announcement.IsVisible() ? DatahubAuthView.AuthLevels.Authenticated : DatahubAuthView.AuthLevels.DatahubSupport;
                    <DatahubAuthView AuthLevel="authLevel">
                        <AnnouncementItem Announcement="@announcement"
                                          OnAnnouncementDeleted="ReloadAnnouncements"
                                          IsHidden="@(announcement.IsDeleted || announcement.IsScheduled())" />
                        @if (i < _announcements.Count - 1)
                        {
                            <MudDivider Class="my-2" />
                        }
                    </DatahubAuthView>
                }
            </MudStack>
        }
        else
        {
            <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
                <DHIcon Icon="@Icons.Material.Outlined.Deck" Size="Size.Large" Class="mt-16 mb-4"/>
                <MudText Typo="Typo.h3">@Localizer["No announcements yet!"]</MudText>
            </MudStack>
        }
    </MudStack>
</DatahubAuthView>

@code {

    private List<Announcement> _announcements = new();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAnnouncements();
    }
    private async Task ReloadAnnouncements()
    {
        _announcements = await _announcementService.GetAnnouncementsAsync();
        StateHasChanged();
    }
}