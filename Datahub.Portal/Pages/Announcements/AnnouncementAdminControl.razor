@using Datahub.Core.Model.Announcements
@using Datahub.Application.Services.Announcements

@inject IAnnouncementService AnnouncementService
@inject ISnackbar _snackbar 

<MudStack Spacing="0">
    <MudText Typo="Typo.body2" Color="@GetColor()">
        @Localizer["Starting from {0} at {1}", Announcement.StartDateTime?.Date.ToString("yyyy-MM-dd")!, Announcement.StartDateTime?.TimeOfDay.ToString("hh\\:mm\\:ss")!]
    </MudText>
    @if (Announcement.EndDateTime.HasValue)
    {
        <MudText Typo="Typo.body2" Color="@GetColor()">
            @Localizer["Until {0} at {1}", Announcement.EndDateTime?.Date.ToString("yyyy-MM-dd")!, Announcement.EndDateTime?.TimeOfDay.ToString("hh\\:mm\\:ss")!]
        </MudText>
    }
    else
    {
        <MudText Typo="Typo.body2" Color="@GetColor()">
            @Localizer["Until further notice"]
        </MudText>
    }
    <MudDivider Class="my-2"/>

    <MudText Typo="Typo.body2">
        @Localizer["Created by {0} on {1}", Announcement.CreatedBy.DisplayName, Announcement.CreatedAt.Date.ToString("yyyy-MM-dd")]
    </MudText>
    @if (Announcement.UpdatedBy is not null)
    {
        <MudText Typo="Typo.body2">
            @Localizer["Updated by {0} on {1}", Announcement.UpdatedBy?.DisplayName!, Announcement.UpdatedAt?.Date.ToString("yyyy-MM-dd")!]
        </MudText>
    }

    <MudDivider Class="my-2"/>
    <MudStack Row Class="mb-2">
        <DHButton Variant="Variant.Text" EndIcon="@Icons.Material.Outlined.Edit" Href="@($"/announcements/edit/{Announcement.Id}")">
            @Localizer["Edit Announcement"]
        </DHButton>
        <DHButton Variant="Variant.Text" EndIcon="@Icons.Material.Outlined.Delete" OnClick="DeleteAnnouncement">
            @Localizer["Delete Announcement"]
        </DHButton>
    </MudStack>
</MudStack>

@code {

    [Parameter]
    public Announcement Announcement { get; set; }

    [Parameter]
    public EventCallback OnAnnouncementDeleted { get; set; }

    private Color GetColor()
    {
        if (Announcement.IsScheduled())
        {
            return Color.Error;
        }

        if (Announcement.IsInCarousel())
        {
            return Color.Success;
        }

        return Color.Default;
    }

    private async Task DeleteAnnouncement()
    {
        var result = await AnnouncementService.DeleteAnnouncementAsync(Announcement.Id);

        if (result)
        {
            _snackbar.Add(Localizer["Article deleted"], Severity.Success); 
            await OnAnnouncementDeleted.InvokeAsync();
        }
        else
        {
            _snackbar.Add(Localizer["Failed to delete article"], Severity.Error);
        }
    }
}