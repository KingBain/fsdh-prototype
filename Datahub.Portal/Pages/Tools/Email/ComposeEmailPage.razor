@using Datahub.Application.Services.Notifications;
@using Datahub.Application.Services.UserManagement
@using Datahub.Application.Services.Notification;
@using Markdig

@inject IDbContextFactory<DatahubProjectDBContext> _dbContextFactory
@inject IDatahubEmailService _emailService
@inject IUserInformationService _userInformationService
@inject IConfiguration _configuration
@inject ISnackbar _snackbar
@inject IJSRuntime _jsRuntime
@inject IGCNotifyService _gcNotifyService

<MudStack Class="mb-4">
  <MudText Typo="Typo.h2">@Localizer["Test Standard Emails"]</MudText>
  <MudText Typo="Typo.body1">@Localizer["This allows you to test the standard FSDH email templates. Emails will only be sent to you."]</MudText>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestAccountCreatedNotification">
    @Localizer["Send Account Created Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestAccountDeletionNoticeNotification">
    @Localizer["Send Account Deletion Notice Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestAccountLockingNoticeNotification">
    @Localizer["Send Account Locking Notice Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestWorkspaceCostNotification">
    @Localizer["Send Workspace Cost Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestDataHubErrorNotification">
    @Localizer["Send DataHub Error Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestDatahubResourceDeletedNotification">
    @Localizer["Send Datahub Resource Deleted Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestDatahubWelcomeNotification">
    @Localizer["Send Welcome Package Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestWorkspaceInactiveNotification">
    @Localizer["Send Workspace Inactive Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestBugReportNotification">
    @Localizer["Send Bug Report Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestInfectedFileNotification">
    @Localizer["Send Infected File Notification"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestStorageScanSuccessEmail">
    @Localizer["Send Storage Scan Success Email"]
  </MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestExternalInviteEmail">
    @Localizer["Send External User Invite Email"]
  </MudButton>
  <MudDivider />

  @*title*@
  <MudStack Row Justify="Justify.SpaceBetween">
    <MudText Typo="Typo.h2">@Localizer["DataHub Email"]</MudText>
  </MudStack>

  @*to field*@
  <MudGrid>
    <MudItem xs="2">
      <MudSelect T="RecipientType" @bind-Value="_recipientType" Label="To:" Variant="Variant.Outlined">
        <MudSelectItem Value="RecipientType.All">
          <MudStack Row Spacing="3">
            <DHIcon Icon="@Icons.Material.Filled.People" />
            <MudText>@Localizer["Everybody"]</MudText>
          </MudStack>
        </MudSelectItem>

        <MudSelectItem Value="RecipientType.Projects">
          <MudStack Row Spacing="3">
            <DHIcon Icon="@Icons.Material.Filled.Groups" />
            <MudText>@Localizer["Workspaces"]</MudText>
          </MudStack>
        </MudSelectItem>

        <MudSelectItem Value="RecipientType.Addresses">
          <MudStack Row Spacing="3">
            <DHIcon Icon="@Icons.Material.Filled.AlternateEmail" />
            <MudText>@Localizer["Emails"]</MudText>
          </MudStack>
        </MudSelectItem>
      </MudSelect>
    </MudItem>

    <MudItem xs="10">
      @if (_recipientType == RecipientType.Projects)
      {
        <MudSelect T="string"                   SelectedValues=@_selectedProjects
                   MultiSelectionTextFunc="@(new Func<List<string>, string>(GetMultiSelectionText))"
                   SelectedValuesChanged=@HandleSelectedValuesChanged                   MultiSelection="true"                   Label="Select workspaces"
                   Variant="Variant.Outlined">

          @foreach (var p in _projects)
          {
            <MudSelectItem Value=@p.Acronym>
              <MudStack Row Spacing="3">
                <MudText>@($"{p.Acronym} - {p.Name}")</MudText>
              </MudStack>
            </MudSelectItem>
          }

        </MudSelect>
      }

      @if (_recipientType == RecipientType.Addresses)
      {
        <MudTextField @bind-Value="_recipients"                      DebounceInterval="250"                      Label=@Localizer["Enter email addresses"]
                      HelperText=@Localizer["Enter email addresses separated by commas"]                      Adornment=@Adornment.End
                      AdornmentIcon=@Icons.Material.Filled.Email                      Variant="Variant.Outlined" />
      }
    </MudItem>
  </MudGrid>

  @*subject*@
  <MudTextField @bind-Value="_subject"                DebounceInterval="250"                Label=@Localizer["Subject"]                Adornment="@Adornment.End"
                AdornmentIcon="@Icons.Material.Filled.Subject"                Variant="Variant.Outlined" />

  @*body*@
  <DHMarkdownEditor InitialValue="@_emailBody" ValueChanged="HandleBodyChanged" />

  @*buttons*@
  <MudStack Row Justify="Justify.FlexStart">
    <DHButton Variant="Variant.Filled"              EndIcon="@Icons.Material.Filled.Send"              Color="Color.Warning"
              Disabled="@IsPreviewDisabled()"              OnClick="@HandleEmailYourself">
      @Localizer["Send Preview to yourself"]
    </DHButton>
    <DHButton Variant="Variant.Filled"              EndIcon="@Icons.Material.Filled.Send"              Color="Color.Primary"
              Disabled="@IsSendDisabled()"              OnClick="@HandleSendEmail">
      @Localizer["Send"]
    </DHButton>
  </MudStack>
</MudStack>


@code {

  private RecipientType _recipientType = RecipientType.All;
  private List<ProjectInfo> _projects = new();
  private HashSet<string> _selectedProjects = new();
  private string _recipients = string.Empty;
  private string _subject = string.Empty;
  private string _emailBody = string.Empty;

  protected override async Task OnInitializedAsync()
  {
    await using var ctx = await _dbContextFactory.CreateDbContextAsync();
    _projects = await ctx.Projects.Select(p => new ProjectInfo(p.Project_Acronym_CD, p.ProjectName)).ToListAsync();
  }

  private bool IsPreviewDisabled()
  {
    return string.IsNullOrEmpty(_subject) || string.IsNullOrEmpty(_emailBody);
  }

  private bool IsSendDisabled()
  {
    if (_recipientType == RecipientType.Projects && _selectedProjects.Count == 0)
      return true;

    if (_recipientType == RecipientType.Addresses && ParseAddresses(_recipients).Count == 0)
      return true;

    return IsPreviewDisabled();
  }

  private void HandleBodyChanged(string value)
  {
    _emailBody = value;
  }

  private string GetMultiSelectionText(List<string> selectedValues)
  {
    return string.Join(", ", selectedValues);
  }

  private void HandleSelectedValuesChanged(IEnumerable<string> values)
  {
    _selectedProjects = new HashSet<string>(values);
  }

  private async Task HandleSendEmail()
  {
    var message = Localizer["Are you sure you want to send your email?"].ToString();
    if (!await _jsRuntime.InvokeAsync<bool>("confirm", message))
      return;

    await SendEmailAsync(async () =>
    {
      switch (_recipientType)
      {
        case RecipientType.All:
          await _emailService.SendAll(GetToAddress(), _subject, GetBodyHtml());
          break;

        case RecipientType.Projects:
          await _emailService.SendToProjects(GetToAddress(), _selectedProjects.ToList(), _subject, GetBodyHtml());
          break;

        case RecipientType.Addresses:
          await _emailService.SendToRecipients(GetToAddress(), ParseAddresses(_recipients), _subject, GetBodyHtml());
          break;
      }
    });
  }

  private async Task HandleEmailYourself()
  {
    await SendEmailAsync(async () =>
    {
      var email = await _userInformationService.GetUserEmail();
      await _emailService.SendToRecipients(email, new(), _subject, GetBodyHtml());
    });
  }

  private async Task SendEmailAsync(Func<Task> action)
  {
    try
    {
      await action.Invoke();
      _snackbar.Add(Localizer["Email sent"], Severity.Success);
    }
    catch
    {
      _snackbar.Add(Localizer["Failed to send the email"], Severity.Warning);
    }
  }

  static List<string> ParseAddresses(string text)
  {
    return (text ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
  }

  private string GetToAddress()
  {
    return _configuration["EmailNotification:SenderAddress"] ??
"ssc.datahub.donotreply-nepasrepondre.datahub.spc@ssc-spc.gc.ca";
  }

  private string GetBodyHtml()
  {
    var pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
    var valueHtml = Markdown.ToHtml(_emailBody ?? string.Empty, pipeline);
    return valueHtml;
  }

  private async Task TestAccountCreatedNotification()
  {
    await _gcNotifyService.SendAccountCreatedNotification(await _userInformationService.GetUserEmail());
  }

  private async Task TestAccountDeletionNoticeNotification()
  {
    await _gcNotifyService.SendAccountDeletionNoticeNotification(await _userInformationService.GetUserEmail(), "25", "5");
  }

  private async Task TestAccountLockingNoticeNotification()
  {
    await _gcNotifyService.SendAccountLockingNoticeNotification(await _userInformationService.GetUserEmail(), "25", "5");
  }

  private async Task TestWorkspaceCostNotification()
  {
    await _gcNotifyService.SendWorkspaceCostNotification(await _userInformationService.GetUserEmail(), "90", "TEST-EMAIL");
  }

  private async Task TestDataHubErrorNotification()
  {
    await _gcNotifyService.SendDataHubErrorNotification("This is a test error", await
_userInformationService.GetUserEmail());
  }

  private async Task TestDatahubResourceDeletedNotification()
  {
    await _gcNotifyService.SendDatahubResourceDeletedNotification(await _userInformationService.GetUserEmail(), "Storage",
"Stockage", "TEST-EMAIL");
  }

  private async Task TestDatahubWelcomeNotification()
  {
    await _gcNotifyService.SendWelcomePackageNotification(await _userInformationService.GetUserEmail());
  }

  private async Task TestWorkspaceInactiveNotification()
  {
    await _gcNotifyService.SendWorkspaceInactiveNotification(await _userInformationService.GetUserEmail(), "30");
  }

  private async Task TestBugReportNotification()
  {
    await _gcNotifyService.SendBugReportNotification("1337", "Test Bug Report", "This is a test bug report email message",
await _userInformationService.GetUserEmail());
  }

  private async Task TestInfectedFileNotification()
  {
    await _gcNotifyService.SendInfectedFileNotification(await _userInformationService.GetUserEmail(), "test_notice.txt",
"TEST NOTICE", "1900-01-01");
  }

  private async Task TestExternalInviteEmail()
  {
    var email = await _userInformationService.GetUserEmail();
    await _gcNotifyService.SendExternalUserInviteNotification(email, "external-user-name-test", "workspace-name-test",
        "inviter-test", "https://dev.fsdh-dhsf.science.cloud-nuage.canada.ca/?locale=en","https://dev.fsdh-dhsf.science.cloud-nuage.canada.ca/?locale=fr");
  }

  private async Task TestStorageScanSuccessEmail()
  {
    var email = await _userInformationService.GetUserEmail();

    var notification = new StorageScanSuccessNotification
    {
      WorkspaceAcronym = "TEST-WS",
      ContainerName = "datahub",
      BlobPath = "uploads/sample-file.csv",
      ScanCompletedOn = DateTimeOffset.UtcNow,
      ScanEngine = "ClamAV",
      UploadedBy = "Datahub Tester",
      UploadedByEmail = email
    };

    var payload = StorageScanNotificationHelper.BuildEventPayload(notification);

    await _gcNotifyService.SendStorageScanSuccessEmailAsync(payload, email);
  }

  enum RecipientType
  {
    All,
    Projects,
    Addresses
  }

  record ProjectInfo(string Acronym, string Name);

}
