        return new HostingServiceInfo
        {
            GcHostingId = GcHostingId,
            Id = Id,
            LeadFirstName = LeadFirstName,
            LeadLastName = LeadLastName,
            DepartmentName = DepartmentName,
            LeadEmail = LeadEmail,
