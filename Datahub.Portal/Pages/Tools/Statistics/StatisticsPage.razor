@using System.Diagnostics
@using ApexCharts
@using Color = MudBlazor.Color
@using Datahub.Application.Services.Cost
@using Datahub.Application.Services.Metadata
@using Datahub.Core.Extensions
@using Datahub.Core.Model.Achievements
@using Datahub.Core.Model.Onboarding
@using Datahub.Core.Model.Projects
@using Datahub.Core.Model.Users
@using Datahub.Portal.Components.Tables
@using Datahub.Portal.Pages.Tools.Statistics.Charts
@using Datahub.Portal.Pages.Tools.Statistics.Objects
@using Datahub.Portal.Pages.Workspace.Reports
@using Datahub.Portal.Pages.Workspace.Reports.Charts
@using Datahub.Shared
@using Datahub.Shared.Entities

@inject IDbContextFactory<DatahubProjectDBContext> DbContextFactory
@inject IMetadataBrokerService MetadataBrokerService
@inject ILogger<StatisticsPage> Logger
@inject ICultureService CultureService

<DHMainContentTitle Title="@Localizer["Statistics & reports"]"/>
@if (!_isLoading)
{
    <MudTabs Elevation="0" Outlined ApplyEffectsToContainer Class="mt-4" PanelClass="pa-6" Rounded="true"
             SliderColor="Color.Primary">
        <CascadingValue Value="Locales">
            <MudTabPanel Text="@Localizer["Summary"]">
                <MudStack Spacing="2">
                    <MudStack Row Wrap="Wrap.Wrap">
                        <ValueCard Value="@(_workspaceCount.ToString())" Label="@Localizer["Workspaces"]"/>
                        <ValueCard Value="@(_resourcesCount.ToString())" Label="@Localizer["Resources"]"/>
                        <ValueCard Value="@(_userCount.ToString())" Label="@Localizer["Users"]"/>
                        <ValueCard Value="@(_activeUserCount.ToString())" Label="@Localizer["Active users"]"/>
                        <ValueCard Value="@(_totalBudget.ToString("C2"))" Label="@Localizer["Total budget"]"/>
                        <ValueCard Value="@(_totalCosts.ToString("C2"))" Label="@Localizer["Total costs"]"/>
                    </MudStack>
                    <MudStack Style="width: 100%">
                        <MudPaper Outlined Elevation="0" Class="pa-4">
                            <AccumulatedCostsArea Costs="_platformCosts" Title="@Localizer["Platform costs"]"
                            />
                        </MudPaper>
                        <MudPaper Outlined Elevation="0" Class="pa-4">
                            <AccumulatedStorageArea Storage="_platformStorage" Title="@Localizer["Platform storage"]"
                            />
                        </MudPaper>
                    </MudStack>
                </MudStack>
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["Departments"]">
                <MudStack Spacing="2">
                    <MudStack Row Wrap="Wrap.Wrap">
                        <ValueCard Value="@(_workspaces.Select(w => w.Department).Where(d => !string.IsNullOrWhiteSpace(d)).Distinct().Count().ToString())"
                                   Label="@Localizer["Departments"]"/>
                        <ValueCard Value="@(_workspaces.GroupBy(w => w.Department).OrderByDescending(g => g.Count()).FirstOrDefault()?.Key ?? Localizer["Unknown"])" 
                                   Label="@Localizer["Largest department"]"/>
                        <ValueCard Value="@(_workspaces.GroupBy(w => w.Department).OrderByDescending(g => g.Count()).FirstOrDefault()?.Count().ToString() ?? "0")"
                                   Label="@Localizer["Workspaces in largest department"]"/>
                        <ValueCard Value="@(_workspaces.GroupBy(w => w.Department).Average(g => g.Count()).ToString("F2"))"
                                   Label="@Localizer["Avg. workspaces per department"]"/>
                    </MudStack>
                    <DHTable TData="DepartmentTableData" Items="@_departments" HideTitle/>
                </MudStack>
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["Workspaces"]">
                <MudStack>
                    <MudStack Row Wrap="Wrap.Wrap">
                        <ValueCard Value="@(_workspaceCount.ToString())" Label="@Localizer["Workspaces"]"/>
                        <ValueCard Value="@(_averageResourcesPerWorkspace.ToString("F2"))"
                                   Label="@Localizer["Avg. resources per workspace"]"/>
                        <ValueCard Value="@(_totalMembersAcrossWorkspaces.ToString())"
                                   Label="@Localizer["Workspace members"]"/>
                        <ValueCard Value="@(_fivePlusMemberWorkspaces.ToString())"
                                   Label="@Localizer["5+ member workspaces"]"/>
                    </MudStack>
                    <MudStack Row Wrap="Wrap.Wrap" AlignItems="AlignItems.Stretch">
                        <WorkspaceCountLineChart Title="@Localizer["Aggregated Workspaces Over Time"]"
                                                 Workspaces="@_workspaces"/>
                    </MudStack>
                    <MudStack Row StretchItems="StretchItems.All" AlignItems="AlignItems.Stretch">
                        <MudStack Style="width: 50%" StretchItems="StretchItems.All">
                            <WorkspaceDepartmentBar Title="@Localizer["Workspaces per department"]"
                                                    Workspaces="@_workspaces" Vertical/>
                        </MudStack>
                        <MudStack Style="width: 50%">
                            <ResourceTypeDonut Title="@Localizer["Resource types"]" Workspaces="@_workspaces"/>
                            <WorkspaceResourceFunnel Title="@Localizer["Workspace Resource Funnel"]"
                                                     Workspaces="@_workspaces"/>
                        </MudStack>
                    </MudStack>
                    <DHTable TData="WorkspaceTableData" Items="@_workspaces" HideTitle/>
                </MudStack>
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["Users"]">
                <MudStack Spacing="4">
                    <MudStack Row Wrap="Wrap.Wrap" Spacing="4">
                        <ValueCard Value="@(_userCount.ToString())" Label="@Localizer["Users"]"/>
                        <ValueCard Value="@(_activeUserCount.ToString())" Label="@Localizer["Active users"]"/>
                        <ValueCard Value="@(_registrationCount.ToString())" Label="@Localizer["Registrations"]"/>
                    </MudStack>
                    <MudStack Row Style="width: 100%">
                        <RegistrationsBar Title="@Localizer["Self registrations"]"
                                          Registrations="@(_allRegistrations)"/>
                    </MudStack>
                    <MudStack Row>
                        <UsersDomainDonut Title="@Localizer["User domains"]" Users="@(_portalUsers)"/>
                        <UserActivityFunnel Title="@Localizer["User activity"]" Users="@(_portalUsers)"/>
                    </MudStack>
                    <DHTable TData="@UserTableData" Items="@_users" HideTitle/>
                </MudStack>
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["Costs"]">
                <MudStack>
                    <MudStack Row Wrap="Wrap.Wrap">
                        <ValueCard Value="@(_totalBudget.ToString("C2"))" Label="@Localizer["Total budget"]"/>
                        <ValueCard Value="@(_totalCosts.ToString("C2"))" Label="@Localizer["Total costs"]"/>
                    </MudStack>
                    <MudStack Style="width: 100%">
                        <MudPaper Outlined Elevation="0" Class="pa-4">
                            <AccumulatedCostsArea Costs="_platformCosts" Title="@Localizer["Platform costs"]"/>
                        </MudPaper>
                    </MudStack>
                </MudStack>
            </MudTabPanel>
            <MudTabPanel Text="@Localizer["Storage"]">
                <MudStack Style="width: 100%">
                    <MudPaper Elevation="0" Outlined Class="pa-4">
                        <AccumulatedStorageArea Storage="_platformStorage" Title="@Localizer["Platform storage"]"/>
                    </MudPaper>
                </MudStack>
            </MudTabPanel>
        </CascadingValue>
    </MudTabs>
    <MudText Style="font-style: italic" Typo="Typo.caption">
        @Localizer["Statistics are real-time displays of database information. Loaded in {0}s", _loadTime.ToString("F2")]
    </MudText>
}
else
{
    <MudTabs Elevation="0" Outlined ApplyEffectsToContainer Class="mt-4" PanelClass="pa-6" Rounded="true"
             SliderColor="Color.Primary">
        <MudTabPanel>
            <TabContent>
                <MudSkeleton Width="80px"/>
            </TabContent>
            <ChildContent>
                <MudStack Spacing="2">
                    <MudStack Row>
                        @foreach (var i in Enumerable.Range(0, 4))
                        {
                            <MudSkeleton Height="60px" Width="100px" SkeletonType="SkeletonType.Rectangle"/>
                        }
                    </MudStack>
                    <MudSkeleton Height="300px" SkeletonType="SkeletonType.Rectangle"/>
                    <MudSkeleton Height="300px" SkeletonType="SkeletonType.Rectangle"/>
                </MudStack>
            </ChildContent>
        </MudTabPanel>
        <MudTabPanel>
            <TabContent>
                <MudSkeleton Width="80px"/>
            </TabContent>
        </MudTabPanel>
    </MudTabs>
}

@code {
    private bool _isLoading = true;
    private double _loadTime;
    private List<DailyServiceCost> _platformCosts = [];
    private List<Project_Storage> _platformStorage = [];
    private List<PortalUser> _portalUsers = [];
    private List<UserTableData> _users = [];
    private List<WorkspaceTableData> _workspaces = [];
    private List<SelfRegistrationDetails> _allRegistrations = [];
    private List<DepartmentTableData> _departments = new();
    private decimal _totalCosts;
    private decimal _totalBudget;
    private int _workspaceCount;
    private int _userCount;
    private int _activeUserCount;
    private int _resourcesCount;
    private int _registrationCount;
    private double _averageResourcesPerWorkspace;
    private int _totalMembersAcrossWorkspaces;
    private int _fivePlusMemberWorkspaces;
    private static List<ChartLocale> Locales => WorkspaceReports.Locales;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        await base.OnInitializedAsync();

        var timer = new Stopwatch();
        timer.Start();
        await LoadPlatformCostsAsync();
        await LoadPlatformStorageAsync();
        await LoadUsersAsync();
        await LoadWorkspacesAsync();
        await LoadRegistrationsAsync();
        await LoadCountsAsync();
        await LoadDepartmentsAsync();
        timer.Stop();
        _loadTime = timer.Elapsed.TotalSeconds;
        Logger.LogInformation("Loaded statistics in {Seconds} seconds", _loadTime);
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadPlatformCostsAsync()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        var allCosts = await ctx.Project_Costs
            .Select(c => new DailyServiceCost
            {
                Date = c.Date,
                Amount = (decimal)c.CadCost,
                Source = c.ServiceName
            })
            .ToListAsync();

        _platformCosts = allCosts
            .GroupBy(c => c.Date.Date)
            .Select(g => new DailyServiceCost
            {
                Date = g.Key,
                Amount = g.Sum(c => c.Amount),
                Source = ""
            })
            .ToList();

        _totalCosts = allCosts.Sum(c => c.Amount);
    }

    private async Task LoadPlatformStorageAsync()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        var allStorage = await ctx.Project_Storage_Avgs.ToListAsync();

        _platformStorage = allStorage
            .GroupBy(c => c.Date.Date)
            .Select(g => new Project_Storage
            {
                Date = g.Key,
                AverageCapacity = g.Sum(c => c.AverageCapacity / (1024 * 1024 * 1024))
            })
            .ToList();
    }

    private async Task LoadUsersAsync()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        var allUsers = await ctx.PortalUsers.Include(u => u.EntraUser).Include(u => u.ExternalUser).ToListAsync();
        var allRegistrations = await ctx.SelfRegistrationDetails.ToListAsync();
        var allWorkspaceMembers = await ctx.UserRolesLinks.Include(m => m.Project).ToListAsync();

        _portalUsers = allUsers;
        _users = allUsers.Select(u => new UserTableData
        {
            Id = u.Id,
            Name = u.DisplayName,
            Email = u.Email,
            RegistrationComment = allRegistrations
                .Where(r => string.Equals(u.Email, r.Email, StringComparison.CurrentCultureIgnoreCase))
                .Select(r => r.Comment)
                .FirstOrDefault(),
            RegistrationDate = allRegistrations
                .Where(r => string.Equals(u.Email, r.Email, StringComparison.CurrentCultureIgnoreCase))
                .Select(r => r.CreatedAt)
                .FirstOrDefault(),
            LastLogin = u.LastLoginDateTime ?? default,
            FirstLogin = u.FirstLoginDateTime ?? default,
            GraphGuid = u.EntraUser?.GraphGuid ?? "-",
			ExternalOID = u.ExternalUser?.ExternalSubject?.ToString() ?? "-",
            Workspaces = new DHTableLinkList
            {
                Links = allWorkspaceMembers
                    .Where(m => m.PortalUser == u)
                    .Select(m => ValueTuple.Create(
                        $"{m.Project.Project_Name} ({m.Project.Project_Acronym_CD})",
                        $"{PageRoutes.WorkspacePrefix}/{m.Project.Project_Acronym_CD}"
                    )).ToList()
            }
        }).ToList();

        _userCount = allUsers.Count;
        _activeUserCount = allUsers.Count(u => u.LastLoginDateTime > DateTime.UtcNow.AddDays(-90));
    }

    private async Task LoadWorkspacesAsync()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        var allWorkspaces = await ctx.Projects
            .Include(w => w.UserRoles)
            .ThenInclude(pu => pu.PortalUser)
            .Include(w => w.Resources)
            .ToListAsync();

        var allCredits = await ctx.Project_Credits.ToListAsync();
        var allResources = await ctx.Project_Resources2.ToListAsync();
        var allWorkspaceMembers = await ctx.UserRolesLinks.ToListAsync();
        var workspaceDepartments = await MetadataBrokerService.ListObjectFieldValues("organization_name");

        _workspaces = allWorkspaces.Select(w => new WorkspaceTableData
        {
            Id = w.Project_ID,
            Acronym = w.Project_Acronym_CD,
            Title = w.Project_Name,
            Description = w.ProjectDescription,
            Budget = w.Project_Budget ?? 0,
            Spent = (decimal)allCredits
                .Where(c => c.ProjectId == w.Project_ID).Select(c => c.Current)
                .FirstOrDefault(),
            ResourceCount = allResources
                .Count(r => r.ProjectId == w.Project_ID && r.Status != TerraformStatus.Deleted),
            Resources = new DHTableLinkList
            {
                Links = w.Resources.Where(r => r.Status != TerraformStatus.Deleted)
                    .Select(r => ValueTuple.Create(TerraformTemplate.ConvertTemplateNameToReadableName(r.ResourceType, CultureService.IsFrench), string.Empty))
                    .ToList()
            },
            MemberCount = allWorkspaceMembers
                .Count(m => m.Project_ID == w.Project_ID && m.RoleId != (int)Project_Role.RoleNames.Removed),
            Members = new DHTableLinkList
            {
                Links = w.UserRoles.Select(u => ValueTuple.Create(u.PortalUser.DisplayName ?? "-", $"/{Localizer[PageRoutes.AccountPrefix]}/?u={u.PortalUser.UserProfileLink()}")).ToList()
            },
            CreatedAt = w.Created_DT,
            UpdatedAt = w.Last_Updated_DT,
            DeletedAt = w.Deleted_DT ?? DateTime.MinValue,
            WorkspaceLeadEmail = w.Project_Admin,
            WorkspaceLead = _portalUsers
                .Where(u => string.Equals(u.Email?.ToLower() ?? string.Empty, w.Project_Admin ?? string.Empty, StringComparison.InvariantCultureIgnoreCase))
                .Select(u => u.DisplayName ?? "-")
                .FirstOrDefault(),
        }).ToList();

        _workspaces.ForEach(w => { w.Department = workspaceDepartments.FirstOrDefault(d => d.Name.Equals(w.Acronym, StringComparison.InvariantCultureIgnoreCase))?.Value; });

        _workspaceCount = allWorkspaces.Count;
        _averageResourcesPerWorkspace = _workspaces.Any() ? _workspaces.Average(w => w.ResourceCount) : 0;
        _totalMembersAcrossWorkspaces = _workspaces.Sum(w => w.MemberCount);
        _fivePlusMemberWorkspaces = _workspaces.Count(w => w.MemberCount >= 5);
        _totalBudget = _workspaces.Sum(w => w.Budget);
    }

    private async Task LoadRegistrationsAsync()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        _allRegistrations = await ctx.SelfRegistrationDetails.ToListAsync();
        _registrationCount = _allRegistrations.Count;
    }

    private async Task LoadCountsAsync()
    {
        await using var ctx = await DbContextFactory.CreateDbContextAsync();
        _resourcesCount = await ctx.Project_Resources2.CountAsync();
    }

    private async Task LoadDepartmentsAsync()
    {
        // Build DepartmentTableData from _workspaces
        _departments = _workspaces
            .Where(w => !string.IsNullOrWhiteSpace(w.Department))
            .GroupBy(w => w.Department)
            .Select(g => new DepartmentTableData
            {
                Name = g.Key,
                WorkspaceCount = g.Count(),
                MemberCount = g.Sum(w => w.MemberCount),
                ResourceCount = g.Sum(w => w.ResourceCount),
                TotalBudget = g.Sum(w => w.Budget),
                TotalSpent = g.Sum(w => w.Spent)
            })
            .OrderByDescending(d => d.WorkspaceCount)
            .ToList();
    }
}
