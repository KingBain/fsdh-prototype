@namespace Datahub.Portal.Scaffold.Layout
@inherits LayoutComponentBase

<MudThemeProvider Theme="@AppTheme.DefaultTheme" />
<MudPopoverProvider />
<MudSnackbarProvider />
<MudLayout Class="scaffold-shell">
    <TopNav ShowWorkspaceLinks="true" />
    <MudMainContent Class="scaffold-main">
        <MudContainer MaxWidth="MaxWidth.False" Class="scaffold-page">
            @Body
        </MudContainer>
        <Footer />
    </MudMainContent>
</MudLayout>
