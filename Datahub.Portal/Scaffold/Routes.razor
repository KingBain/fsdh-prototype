@namespace Datahub.Portal.Scaffold
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            @if (routeData.PageType.Namespace?.StartsWith("Datahub.Portal.Scaffold.Pages.Public") == true)
            {
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(PublicLayout)" />
            }
            else
            {
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(PortalLayout)">
                    <NotAuthorized>
                        <LayoutView Layout="@typeof(PublicLayout)">
                            <AuthRequired />
                        </LayoutView>
                    </NotAuthorized>
                </AuthorizeRouteView>
            }
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(PublicLayout)">
                <Datahub.Portal.Scaffold.Pages.Public.NotFoundPage />
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
