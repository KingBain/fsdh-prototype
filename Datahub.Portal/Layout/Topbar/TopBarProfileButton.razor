@inject IUserInformationService _userInformationService
@inject NavigationManager _navigation_manager

@using Datahub.Application.Services.UserManagement
@using Datahub.Core.Model.Achievements
@using Datahub.Core.Model.Users;
@using Datahub.Portal.Components.User
@using Microsoft.Identity.Web
@using MudBlazor.Utilities
@using System.Security.Claims


<MudHidden Breakpoint="Breakpoint.MdAndDown" Invert="true">
    <MudText Typo="Typo.h2" Class="sr-only">@Localizer["Settings"]</MudText>
    <DHButton Size="Size.Small" Href="@Localizer[PageRoutes.AccountDefault]" Disabled=@(_viewedUser is null)>
        <MudText>@Localizer["Settings"]</MudText>
    </DHButton>
    <MudText Typo="Typo.h2" Class="sr-only">@Localizer["Language selection"]</MudText>
    <LanguageToggle @ref="_languageToggle" Size="Size.Small" />
    <MudText Typo="Typo.h2" Class="sr-only">@Localizer["Sign in or out"]</MudText>
    <DHButton HtmlTag="button" Style="margin-top:20px; text-wrap: nowrap" OnClick="@HandleLogOut" Size="Size.Small" Disabled=@(_viewedUser is null)>
        <MudText>@Localizer["Sign out"]</MudText>
    </DHButton>
</MudHidden>
<MudHidden Breakpoint="Breakpoint.LgAndUp" Invert="true">
    <MudText Typo="Typo.h2" Class="sr-only">@Localizer["Settings"]</MudText>
    <DHButton Size="Size.Medium" Href="@Localizer[PageRoutes.AccountDefault]" Disabled=@(_viewedUser is null)>
        <MudText>@Localizer["Settings"]</MudText>
    </DHButton>
    <MudText Typo="Typo.h2" Class="sr-only">@Localizer["Language selection"]</MudText>
    <LanguageToggle @ref="_languageToggle" Size="Size.Medium" />
    <MudText Typo="Typo.h2" Class="sr-only">@Localizer["Sign in or out"]</MudText>
    <DHButton HtmlTag="button" Style="text-wrap: nowrap" OnClick="@HandleLogOut" Size="Size.Medium" Disabled=@(_viewedUser is null)>
        <MudText>@Localizer["Sign out"]</MudText>
    </DHButton>
</MudHidden>


@code {


    private ClaimsPrincipal? _viewedUser;
    private bool _isEntraUser;

    private LanguageToggle _languageToggle = null!;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        if (_viewedUser is not null)
        {
            return;
        }
        _viewedUser = await _userInformationService.GetAuthenticatedUser();
        _isEntraUser = await _userInformationService.IsEntraUser();
    }

    private void HandleLogOut()
    {
        if (_isEntraUser)
        {
            _navigation_manager.NavigateTo("MicrosoftIdentity/Account/SignOut", true);
        }
        else
        {
            _navigation_manager.NavigateTo($"/gccf/logout?locale={CultureInfo.CurrentCulture.Name}", true);
        }
    }

    private async Task HandleLanguageToggle(MouseEventArgs arg)
    {
        await _languageToggle.ToggleLanguage();
    }

}
