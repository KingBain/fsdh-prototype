@using Datahub.Application.Services.UserManagement
@inject IUserCircuitCounterService UserCircuitCounterService
@inject IStringLocalizer Localizer

<MudCard style="margin: 2rem;">
    <MudCardContent>
        <div style="margin: 1rem;">
            <MudText>@ContentMessage()</MudText>
        </div>            
    </MudCardContent>
</MudCard>

@code {

    private string ContentMessage()
    {
        var template = Localizer["TooManyTabsMessage"] ?? "";
        return template.Replace("{}", UserCircuitCounterService.GetSessionCount().ToString());
    }

}